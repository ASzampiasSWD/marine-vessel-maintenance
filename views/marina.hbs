<!DOCTYPE html>
<html lang="en">
<head>
	<title>Save the Zebras</title>
	<meta charset="utf-8" />
	<meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no" />
	<link rel="stylesheet" type="text/css" href="styles/bootstrap.min.css" />
	<link rel="stylesheet" type="text/css" href="styles/index.css" />
	<link rel="stylesheet" type="text/css" href="styles/font.css" />
	<style type="text/css">
		.table-bordered th,
		.table-bordered td {
			border-color: #88a7d9 !important;
		}
	</style>
</head>
<body>
	<nav class="navbar navbar-expand-lg navbar-dark bg-dark">
		<a class="navbar-brand" href="">Boat Repair LLC</a>
		<button class="navbar-toggler" type="button" data-toggle="collapse" data-target="#navbarSupportedContent"
			aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
			<span class="navbar-toggler-icon"></span>
		</button>

		<div class="collapse navbar-collapse" id="navbarSupportedContent">
			<ul class="navbar-nav mr-auto">
				<li class="nav-item">
					<a class="nav-link" href="/">Add Repair</a>
				</li>
				<li class="nav-item active">
					<a class="nav-link" href="/list">Fixed Boat List</a>
				</li>
				<li class="nav-item">
					<a class="nav-link" href="/join">Add Technician</a>
				</li>
                <li class="nav-item">
					<a class="nav-link" href="/guide">Guide</a>
				</li>
                 <li class="nav-item">
					<a class="nav-link" href="/leaderboard">Leaderboard</a>
				</li>
			</ul>
		</div>
	</nav>
	<br /><br />
	<div class="w-75 justify-content-center" style="margin: 0 auto;">
		<div class="row">
			<div class="col">
				<h2>Marina Stats: {{{marinaId}}}</h2>
			</div>
		</div>
		<hr />
        <h3>Marina Information</h3>
        <table class="table table-bordered w-75" id="marinaTable">
            <thead style="background-color: #9db9fa;">
                <tr>
                    <th scope="col">Street Name</th>
                    <th scope="col">City</th>
                    <th scope="col">State</th>
                    <th scope="col">Country</th>
                </tr>
            </thead>
            <tbody id="marinaTBody">
                <tr>
                    <td>{{{marinaRow.street_name}}}</td>
                    <td>{{{marinaRow.city}}}</td>
                    <td>{{{marinaRow.us_state}}}</td>
                    <td>{{{marinaRow.country}}}</td>
                </tr>
            </tbody>
		</table>
        <h3>Leaderboard</h3>
        <table class="table table-bordered w-75" id="leaderboardTable">
            <thead style="background-color: #9db9fa;">
                <tr>
                    <th scope="col">Marina Rank</th>
                    <th scope="col">Total Vessels Fixed</th>
                    <th scope="col">Total Money Saved</th>
                    <th scope="col">Total Spent on Repairs</th>
                </tr>
            </thead>
            <tbody id="leaderboardTBody">
            </tbody>
		</table>
        <h3>All Technicians</h3>
        <table class="table table-bordered w-75" id="technicianTable">
            <thead style="background-color: #9db9fa;">
                <tr>
                    <th scope="col">Technician ID</th>
                    <th scope="col">First Name</th>
                    <th scope="col">Last Name</th>
                    <th scope="col">Joined On</th>
                </tr>
            </thead>
            <tbody id="technicianTBody">
            </tbody>
		</table>
		<h3>All Repairs</h3>
		<table class="table table-bordered" id="repairTable">
			<thead style="background-color: #9db9fa;">
				<tr>
					<th scope="col">Repair ID</th>
					<th scope="col">Hull Number</th>
					<th scope="col">Vessel Type</th>
					<th scope="col">Tech ID</th>
                    <th scope="col">Marina ID</th>
					<th scope="col">Dock Location</th>
					<th scope="col">Station ID</th>
					<th scope="col">Repair Cost</th>
					<th scope="col">Money Saved</th>
					<th scope="col">Date/Time Fixed</th>
				</tr>
			</thead>
			<tbody id="repairTBody">
			</tbody>
		</table>
	</div>
	<br /><br />
	<script type="text/javascript" src="scripts/jquery-3.3.1.slim.min.js"></script>
	<script type="text/javascript" src="scripts/popper.min.js"></script>
	<script type="text/javascript" src="scripts/bootstrap.min.js"></script>
	<script type="text/javascript" src="scripts/sharedUtils.js"></script>
    <script>
        		function updateTable(event) {
			changeTableContents(event.target.value);
		}
		//const searchBar = document.getElementById('searchBar');
		//searchBar.addEventListener('input', updateTable);

		window.onload = function () {
			changeTableContents("");
            setTableTechnicianContents();
            setLeaderboard();

		}

        function setLeaderboard() {
           let tableBody = document.getElementById("leaderboardTBody");
			let technicianRows = {{{technicianRows}}};
            const urlParams = new URLSearchParams(window.location.search);
            const marinaId = urlParams.get('marinaid');
            tableBody.innerHTML = "";
            let repairRow = {{{repairRow}}};
            let placement = 1;
            let placementText = '';
            let totalVesselsFixed = 0;
            let totalMoneySaved = 0.00;
            let totalRepairCost = 0.00;
           Object.keys(repairRow).forEach(key => {
            const value = repairRow[key];
            if (value.marina_id.includes(marinaId)) {
                console.log(key);
                placement += parseInt(key);
                totalVesselsFixed = value.count;
                totalMoneySaved = value.money_saved;
                totalRepairCost = value.repair_cost;
            }
           });
           placementText = placement + " out of " + repairRow.length;
            let newRow = tableBody.insertRow(-1);
            // Insert new cells into the row in the correct order (index starts at 0)
            let cell1 = newRow.insertCell(0);
            let cell2 = newRow.insertCell(1);
            let cell3 = newRow.insertCell(2);
            let cell4 = newRow.insertCell(3);
            // Add data to the cells
            cell1.innerHTML = placementText;
            cell2.innerHTML = totalVesselsFixed;
            cell3.innerHTML = '$' + usMoneyFormatter.format(totalMoneySaved);
            cell4.innerHTML = '$' + usMoneyFormatter.format(totalRepairCost);
        }



        function setTableTechnicianContents() {
			let tableBody = document.getElementById("technicianTBody");
			let technicianRows = {{{technicianRows}}};
			tableBody.innerHTML = "";
			let bFound = false;
			Object.keys(technicianRows).forEach(key => {
				const value1 = technicianRows[key];
				//if (value.technician_id.includes(strTechnicianId)) {
					// Insert a new row at the end of the tbody (-1 index means the last position)
					let newRow = tableBody.insertRow(-1);
					bFound = true;
					// Insert new cells into the row in the correct order (index starts at 0)
					let cell1 = newRow.insertCell(0);
					let cell2 = newRow.insertCell(1);
					let cell3 = newRow.insertCell(2);
					let cell4 = newRow.insertCell(3);
					// Add data to the cells
					cell1.innerHTML = '<a href="/technician?technicianid=' + value1.technician_id + '">' + value1.technician_id + '</a>';
                    cell2.innerHTML = value1.first_name;
                    cell3.innerHTML = value1.last_name;
                    cell4.innerHTML = transformDate(value1.created_at);
				//}
			});
        }

		function changeTableContents(strTechnicianId) {
			let tableBody = document.getElementById("repairTBody");
			let rows = {{{rows}}};
			tableBody.innerHTML = "";
			let bFound = false;
			Object.keys(rows).forEach(key => {
				const value = rows[key];
				if (value.technician_id.includes(strTechnicianId)) {
					// Insert a new row at the end of the tbody (-1 index means the last position)
					let newRow = tableBody.insertRow(-1);
					bFound = true;
					// Insert new cells into the row in the correct order (index starts at 0)
					let cell1 = newRow.insertCell(0);
					let cell2 = newRow.insertCell(1);
					let cell3 = newRow.insertCell(2);
					let cell4 = newRow.insertCell(3);
					let cell5 = newRow.insertCell(4);
					let cell6 = newRow.insertCell(5);
					let cell7 = newRow.insertCell(6);
					let cell8 = newRow.insertCell(7);
					let cell9 = newRow.insertCell(8);
                    let cell10 = newRow.insertCell(9);
					// Add data to the cells
					cell1.innerHTML = value.repair_id;
					cell2.innerHTML = '<a href="/vessel?vesselid=' + value.hull_id_number + '">' + value.hull_id_number + '</a>';
					cell3.innerHTML = value.vessel_type_name;
					cell4.innerHTML = '<a href="/technician?technicianid=' + value.technician_id + '">' + value.technician_id + '</a>';
                    cell5.innerHTML = '<a href="/marina?marinaid=' + value.marina_id + '">' + value.marina_id + '</a>';
					cell6.innerHTML = value.dock_location;
					cell7.innerHTML = value.birth_number;
					cell8.innerHTML = '$' + usMoneyFormatter.format(value.repair_cost);
					cell9.innerHTML = '$' + usMoneyFormatter.format(value.money_saved);
					cell10.innerHTML = transformDate(value.date_time_fixed);
				}
			});
			if (bFound == false) {
				let newRow = tableBody.insertRow(-1);
				let cell = newRow.insertCell(0);
				cell.innerHTML = 'No contents were found';
				cell.colSpan = 10;
				cell.style.textAlign = 'center';
			}
		}
    </script>
	<br /><br /><br /><br />
</body>
</html>